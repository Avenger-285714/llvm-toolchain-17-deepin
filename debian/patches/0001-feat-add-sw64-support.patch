+def Sw64_sbt   : SDNode<"Sw64ISD::SBT",     SDTIntBinOp, []>;
+def Sw64_cbt   : SDNode<"Sw64ISD::CBT",     SDTIntBinOp, []>;
+def Sw64_addpi   : SDNode<"Sw64ISD::ADDPI",   SDTIntUnaryOp, []>;
+def Sw64_addpis  : SDNode<"Sw64ISD::ADDPIS",  SDTIntUnaryOp, []>;
