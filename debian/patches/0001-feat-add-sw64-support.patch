index 000000000..fcb258de9
--- /dev/null
+++ b/llvm/lib/Target/Sw64/Sw64SchedCore3.td
@@ -0,0 +1,236 @@
+//===- Sw64Schedule.td - Sw64 Scheduling Definitions -----*- tablegen -*-===//
+// 
+//                     The LLVM Compiler Infrastructure
+//
