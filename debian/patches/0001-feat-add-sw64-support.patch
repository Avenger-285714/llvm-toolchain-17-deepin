+static unsigned Sw64RevCondCode(unsigned Opcode) {
+  switch (Opcode) {
+  case Sw64::BEQ:
+    return Sw64::BNE;
+  case Sw64::BNE:
+    return Sw64::BEQ;
+  case Sw64::BGE:
+    return Sw64::BLT;
+  case Sw64::BGT:
+    return Sw64::BLE;
+  case Sw64::BLE:
+    return Sw64::BGT;
+  case Sw64::BLT:
+    return Sw64::BGE;
+  case Sw64::BLBC:
+    return Sw64::BLBS;
+  case Sw64::BLBS:
+    return Sw64::BLBC;
+  case Sw64::FBEQ:
+    return Sw64::FBNE;
+  case Sw64::FBNE:
+    return Sw64::FBEQ;
+  case Sw64::FBGE:
+    return Sw64::FBLT;
+  case Sw64::FBGT:
+    return Sw64::FBLE;
+  case Sw64::FBLE:
+    return Sw64::FBGT;
+  case Sw64::FBLT:
+    return Sw64::FBGE;
+  default:
+    llvm_unreachable("Unknown opcode");
+  }
+  return 0; // Not reached
+}
