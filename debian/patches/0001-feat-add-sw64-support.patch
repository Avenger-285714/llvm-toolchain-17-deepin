+
+#ifndef HUH20190119_SWLLVM // set RTLIB of names
+  // return R
+  setLibcallName(RTLIB::OEQ_F128, "_OtsEqlX");
+  setLibcallName(RTLIB::UNE_F128, "_OtsNeqX");
