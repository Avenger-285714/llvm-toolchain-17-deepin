+#ifndef ZHAIYH20210815_SIMD
+    for (const auto &Feature : Features) {
+      if (Feature == "+simd")
+        HasSIMD = true;
+      if (Feature == "+core3b")
+        HasCore3 = true;
+      if (Feature == "+core4")
