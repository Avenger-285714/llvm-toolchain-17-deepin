+private:
+  Sw64ELFStreamer *Streamer;
+  MCContext &Context;
+  const MCRegisterClass *GPRCRegClass;
+  const MCRegisterClass *F4RCRegClass;
+  const MCRegisterClass *F8RCRegClass;
+#ifndef HANYH20230320_SIMD
+  const MCRegisterClass *V256LRegClass;
+#endif
+};
