+  case Sw64ISD::VSRL_BY_SCALAR:         return "Sw64ISD::VSRL_BY_SCALAR";
+  case Sw64ISD::VSRA_BY_SCALAR:         return "Sw64ISD::VSRA_BY_SCALAR";
+  case Sw64ISD::VEXTRACT_SEXT_ELT:      return "Sw64ISD::VEXTRACT_SEXT_ELT";
+#endif
+#ifndef ZENGZH20230413_SIMD
+  case Sw64ISD::VBROADCAST:         return "Sw64ISD::VBROADCAST";
+  case Sw64ISD::VBROADCAST_LD:      return "Sw64ISD::VBROADCAST_LD";
+  case Sw64ISD::VTRUNCST:           return "Sw64ISD::VTRUNCST";
+#endif
+  }
+
+  return nullptr;
+}
