+#ifndef ZHAIYH20200717_SIMD
+bool Sw64AsmParser::parseMemOffset(const MCExpr *&Res, bool isParenExpr) {
+  SMLoc S;
+
+  if (isParenExpr)
+    return getParser().parseParenExprOfDepth(0, Res, S);
+  return getParser().parseExpression(Res);
+}
+#endif
