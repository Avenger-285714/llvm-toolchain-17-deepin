+def Sw64_crc32b : SDNode<"Sw64ISD::CRC32B",   SDTIntBinOp, []>;
+def Sw64_crc32h : SDNode<"Sw64ISD::CRC32H",   SDTIntBinOp, []>;
+def Sw64_crc32w : SDNode<"Sw64ISD::CRC32W",   SDTIntBinOp, []>;
+def Sw64_crc32l : SDNode<"Sw64ISD::CRC32L",   SDTIntBinOp, []>;
