+#ifndef ZENGZH20230424_SIMD
+  setMinStackArgumentAlignment(Align(32));
+#endif
+  setMinFunctionAlignment(Align(8));
+#ifndef ZHAOAN20220224_OPT_MUL
+  setTargetDAGCombine(ISD::MUL);
