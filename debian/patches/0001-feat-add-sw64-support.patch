+EVT Sw64TargetLowering::getSetCCResultType(const DataLayout &, LLVMContext &,
+                                           EVT VT) const {
+  // Refer to other.
+  if (!VT.isVector())
+    return MVT::i64;
+
+  return VT.changeVectorElementTypeToInteger();
+}
