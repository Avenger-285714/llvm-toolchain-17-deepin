+def callseq_end   : SDNode<"ISD::CALLSEQ_END",   SDT_Sw64CallSeqEnd,
+                           [SDNPHasChain, SDNPOptInGlue, SDNPOutGlue]>;
+#ifndef BAOYL2022_8A
