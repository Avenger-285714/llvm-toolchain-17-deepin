+//////////////////////////////////////////////
+// Integer Araith Intrinsic Sw64
+// ///////////////////////////////////////////
+
+// Caculate adden for given vector as int32_tx8,
+// it isn't normal overflow result.
+static __inline__ intv8 __DEFAULT_FN_ATTRS
+simd_vaddw(intv8 a, intv8 b) {
+  return a + b;
+}
+
+static __inline__ intv8 __DEFAULT_FN_ATTRS
+simd_vaddwi(intv8 a, const int32_t b) {
+  intv8 tmp = __extension__(intv8){b, b, b, b,
+                                           b, b, b, b};
+  return a + tmp;
+}
+
+static __inline__ intv8 __DEFAULT_FN_ATTRS
+simd_vsubw(intv8 a, intv8 b) {
+  return a - b;
+}
+
+static __inline__ intv8 __DEFAULT_FN_ATTRS
+simd_vsubwi(intv8 a, const int32_t b) {
+  intv8 tmp = __extension__(intv8){b, b, b, b,
+                                           b, b, b, b};
+  return a - tmp;
+}
+
+static __inline__ intv8 __DEFAULT_FN_ATTRS
+simd_vucaddw(intv8 a, intv8 b) {
+  return __builtin_sw_vucaddw(a, b);
+}
+
+static __inline__ intv8 __DEFAULT_FN_ATTRS
+simd_vucaddwi(intv8 a, const int32_t b) {
+  intv8 tmp = __extension__(intv8){b, b, b, b,
+                                           b, b, b, b};
